# ════════════════════════════════════════════
#   Copy this file as .env and fill values
#   cp .env.example .env
# ════════════════════════════════════════════

# ──── Application ────
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# ──── Database (MySQL) ────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=ecommerce
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_USER=ecommerce_user
MYSQL_PASSWORD=CHANGE_ME_USER_PASSWORD

# ──── JWT ────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_EXPIRATION=86400000

# ──── Stripe ────
STRIPE_API_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# ──── Spring JPA ────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false